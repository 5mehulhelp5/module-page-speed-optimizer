<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <update handle="styles"/>
    <body>
        <referenceContainer name="content">
            <block class="Magento\Backend\Block\Template" name="etechflow_pso_update_notice" template="ETechFlow_PageSpeedOptimizer::update-notice.phtml" before="-" cacheable="false"/>
            <block class="ETechFlow\PageSpeedOptimizer\Block\Adminhtml\Diagnose\Page"
                   name="etechflow.pso.diagnose.page"
                   template="ETechFlow_PageSpeedOptimizer::diagnose/page.phtml"
                   cacheable="false"/>
        </referenceContainer>
    </body>
</page>
